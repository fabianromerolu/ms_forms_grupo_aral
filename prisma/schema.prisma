generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MaintenanceTipo {
  PREVENTIVO
  CORRECTIVO
}

enum MaintenanceSubTipo {
  CUBIERTA
  METALMECANICO_TIENDA
  PUERTA_AUTOMATICA
  PUNTOS_PAGO
  REDES_HIDROSANITARIAS
  REDES_ELECTRICAS
  ESTIBADOR
  CORTINA_ENROLLABLE
  CARRITOS_MERCADO

  OBRA_CIVIL
  METALMECANICA
  ELECTRICA
  EQUIPOS_ESPECIALES
}

enum ReportEstado {
  ENVIADO
}

model Report {
  id                 String               @id @db.Uuid
  createdAt          DateTime             @default(now())
  clientCreatedAt    DateTime?
  tecnicoIp          String
  incidenciaPrincipal String?
  incidencias         String[]
  departamentoTienda  String?
  ciudadTienda        String?
  tienda              String
  descripcionIncidencia String?
  nombreTecnico      String
  cedulaTecnico      String
  telefonoTecnico    String
  tipo               MaintenanceTipo
  subTipoPrincipal   MaintenanceSubTipo?
  subTipos           MaintenanceSubTipo[]
  observaciones      String?
  fotosAntes         String[]
  fotosDespues       String[]
  responsable        Json?
  checklist          Json?
  extra              Json
  responsablePdfUrl  String?
  incidenciasRemote  Json?
  estado             ReportEstado         @default(ENVIADO)
  searchText         String               @db.Text
  updatedAt          DateTime             @updatedAt
  @@index([createdAt])
  @@index([tipo])
  @@index([subTipoPrincipal])
  @@index([incidenciaPrincipal])
  @@index([tienda])
  @@index([departamentoTienda])
  @@index([ciudadTienda])
}